# Copia este archivo a .env y rellena con tus datos
# NO subas el archivo .env a GitHub (está en .gitignore)

# Token del bot de Discord (obtén de https://discord.com/developers/applications)
DISCORD_TOKEN=tu_token_secreto_aqui

# ID del canal donde enviar recordatorios (opcional, se configura con !setup en el servidor)
CHANNEL_ID=

# ID del rol a mencionar (opcional, se configura con !setup en el servidor)
ROLE_ID=
